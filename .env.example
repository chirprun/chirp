# LLM judge: openai (default) | deepseek | anthropic
LLM_JUDGE_PROVIDER=openai

# Primary key for llm_judge when using OpenAI or DeepSeek (same env var for both)
OPENAI_API_KEY=

# Only if LLM_JUDGE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Optional: override model (defaults: gpt-4o-mini, deepseek-chat, claude-sonnet-4-20250514)
# LLM_JUDGE_MODEL=

# Optional: custom API base (DeepSeek defaults to https://api.deepseek.com when LLM_JUDGE_PROVIDER=deepseek)
# OPENAI_BASE_URL=

DATABASE_URL=sqlite+aiosqlite:///./chirp.db
DEMO_MODE=false
